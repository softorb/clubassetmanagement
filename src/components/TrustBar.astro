---
const features = [
  { icon: "shield", title: "Permanent Capital", desc: "No fund timelines or forced exits" },
  { icon: "handshake", title: "Founder-Friendly", desc: "We honor your legacy and team" },
  { icon: "clock", title: "Rapid Execution", desc: "30–60 day close timelines" },
  { icon: "lock", title: "Total Confidentiality", desc: "Discreet, NDA-protected process" },
];
---

<section class="trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      {features.map((f, i) => (
        <div class="trust-bar__item reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="trust-bar__icon">
            {f.icon === 'shield' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            )}
            {f.icon === 'handshake' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"/></svg>
            )}
            {f.icon === 'clock' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            )}
            {f.icon === 'lock' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            )}
          </div>
          <div>
            <h4 class="trust-bar__title">{f.title}</h4>
            <p class="trust-bar__desc">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: var(--color-surface);
    padding: 4rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .trust-bar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .trust-bar__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .trust-bar__icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(197, 165, 90, 0.08);
    border-radius: var(--radius-md);
    color: var(--color-accent);
  }

  .trust-bar__title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .trust-bar__desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .trust-bar__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .trust-bar__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
