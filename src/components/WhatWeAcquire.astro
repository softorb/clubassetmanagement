---
import { siteConfig } from '../config/site';
const { acquisitionCriteria } = siteConfig;
---

<section class="section section--alt" id="criteria">
  <div class="container">
    <div class="section__header reveal">
      <span class="section__label">Acquisition Focus</span>
      <h2>What We Acquire</h2>
      <p class="section__subtitle">
        We seek established, profitable businesses with defensible market positions
        and strong management teams. Our flexible approach accommodates a range of transaction structures.
      </p>
    </div>

    <div class="criteria__grid">
      <div class="criteria__card reveal">
        <div class="criteria__card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="criteria__card-title">Revenue Range</h3>
        <p class="criteria__card-value">{acquisitionCriteria.revenue}</p>
        <p class="criteria__card-desc">Annual revenue from established operations with consistent performance history.</p>
      </div>

      <div class="criteria__card reveal delay-100">
        <div class="criteria__card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h3 class="criteria__card-title">EBITDA</h3>
        <p class="criteria__card-value">{acquisitionCriteria.ebitda}</p>
        <p class="criteria__card-desc">Demonstrated, sustainable earnings with identifiable growth potential.</p>
      </div>

      <div class="criteria__card reveal delay-200">
        <div class="criteria__card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h3 class="criteria__card-title">Geography</h3>
        <p class="criteria__card-value">{acquisitionCriteria.geographies}</p>
        <p class="criteria__card-desc">Businesses headquartered and primarily operating within North America.</p>
      </div>
    </div>

    <div class="criteria__industries reveal delay-300">
      <h3 class="criteria__industries-title">Target Industries</h3>
      <div class="criteria__industries-grid">
        {acquisitionCriteria.industries.map((industry) => (
          <div class="criteria__industry-tag">
            <span class="criteria__industry-dot"></span>
            {industry}
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-4 reveal delay-400">
      <a href="/criteria" class="btn btn--primary">View Full Criteria</a>
    </div>
  </div>
</section>

<style>
  .criteria__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .criteria__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem;
    text-align: center;
    transition: all var(--transition-base);
  }

  .criteria__card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
    border-color: var(--color-accent);
  }

  .criteria__card-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(197, 165, 90, 0.08);
    border-radius: 50%;
    color: var(--color-accent);
    margin: 0 auto 1.25rem;
  }

  .criteria__card-title {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .criteria__card-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .criteria__card-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .criteria__industries {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    text-align: center;
  }

  .criteria__industries-title {
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
  }

  .criteria__industries-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .criteria__industry-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .criteria__industry-dot {
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .criteria__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
