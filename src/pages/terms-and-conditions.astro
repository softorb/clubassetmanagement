---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const effectiveDate = "April 10, 2026";
---

<BaseLayout title="Terms & Conditions" description="Terms and conditions governing the use of Club Asset Management, LLC website and services.">
  <PageHero
    label="Legal"
    title="Terms & Conditions"
    subtitle={`Effective Date: ${effectiveDate}`}
  />

  <section class="section">
    <div class="container container--narrow">
      <div class="legal-content">
        <p>
          By accessing or using the services of Club Asset Management, LLC ("Company"), you agree to the
          following Terms and Conditions.
        </p>

        <h2>Services</h2>
        <p>
          Club Asset Management, LLC provides real estate consultation, acquisition, investment, and related
          advisory services.
        </p>

        <h2>No Guarantee</h2>
        <p>
          The Company makes no guarantees regarding investment performance, property acquisition outcomes, or
          financial results.
        </p>

        <h2>Communications Consent</h2>
        <p>
          By submitting your phone number through our website contact forms, property inquiry forms, consultation
          requests, or other direct communications with Club Asset Management, LLC, you consent to receive
          communications from us via phone call, email, and SMS text messaging regarding your inquiry and our
          services.
        </p>

        <h2>SMS Terms</h2>
        <p>By opting in to receive SMS communications:</p>
        <ul>
          <li>You consent to receive text messages from Club Asset Management, LLC</li>
          <li>Message frequency may vary</li>
          <li>Message and data rates may apply</li>
          <li>Reply STOP to opt out</li>
          <li>Reply HELP for assistance</li>
        </ul>

        <h2>Opt-Out</h2>
        <p>
          You may opt out of SMS communications at any time by replying STOP.
        </p>

        <h2>Intellectual Property</h2>
        <p>
          All website content, branding, graphics, and materials are property of Club Asset Management, LLC
          unless otherwise stated.
        </p>

        <h2>Limitation of Liability</h2>
        <p>
          Club Asset Management, LLC shall not be liable for indirect, incidental, or consequential damages
          arising from use of our services or website.
        </p>

        <h2>Governing Law</h2>
        <p>
          These Terms shall be governed by the laws of the applicable jurisdiction in which the Company operates.
        </p>

        <h2>Contact Information</h2>
        <p>
          <strong>Club Asset Management, LLC</strong><br />
          Email: <a href="mailto:info@clubassetmanagement.com">info@clubassetmanagement.com</a><br />
          Website: <a href="https://clubassetmanagement.com">https://clubassetmanagement.com</a>
        </p>

        <h2>Updates</h2>
        <p>
          We reserve the right to update these Terms at any time. Continued use of our website constitutes
          acceptance of updated Terms.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-content {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .legal-content h2 {
    font-size: 1.375rem;
    margin: 2.5rem 0 1rem;
    color: var(--color-primary);
  }

  .legal-content h2:first-child {
    margin-top: 0;
  }

  .legal-content p {
    margin-bottom: 1rem;
  }

  .legal-content ul {
    list-style: none;
    margin-bottom: 1.25rem;
    padding-left: 0;
  }

  .legal-content ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .legal-content ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .legal-content a {
    color: var(--color-accent);
    transition: opacity var(--transition-fast);
  }

  .legal-content a:hover {
    opacity: 0.8;
  }

  .legal-content strong {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
